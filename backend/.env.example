APP_NAME=Data Shield Backend
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
DATABASE_URL=sqlite:///./data/app.db
AUTO_CREATE_TABLES=true
# JSON array or comma-separated list both work.
# Local dev:
# CORS_ORIGINS=["http://localhost:5173"]
# Lovable deployment:
# CORS_ORIGINS=["https://your-lovable-app-domain"]
CORS_ORIGINS=["http://localhost:5173"]
WORKFLOW_WORKER_ENABLED=true
WORKFLOW_WORKER_COMMAND="./node_modules/.bin/vite-node scripts/backend-workflow-runner.ts"
WORKFLOW_WORKER_CWD=..
WORKFLOW_DISCOVERY_MODE=hybrid

# Required once live LLM-backed workflow is connected
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Required once browser-backed automation is enabled on a machine:
# PATH="$HOME/.nvm/versions/node/v20.20.0/bin:$PATH" npm install
# PATH="$HOME/.nvm/versions/node/v20.20.0/bin:$PATH" npx playwright install chromium

# Required when email-based opt-outs are enabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
PRIVACY_FROM_EMAIL=
