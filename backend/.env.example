APP_NAME=Data Shield Backend
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
DATABASE_URL=sqlite:///./data/app.db
AUTO_CREATE_TABLES=true
CORS_ORIGINS=["http://localhost:5173"]

# Required once live LLM-backed workflow is connected
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Required when email-based opt-outs are enabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
PRIVACY_FROM_EMAIL=
